{
  "template_files": {
    "default.tmpl": "{{ define \"slack.syntax.title\" }}[{{ .Status | toUpper }}{{ if eq .Status \"firing\" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .GroupLabels.alertname }}{{ end }}\n\n{{ define \"slack.syntax.text\" }}\n{{ range .Alerts }}\n*Alert:* {{ .Annotations.summary }}\n*Description:* {{ .Annotations.description }}\n*Severity:* {{ .Labels.severity | toUpper }}\n*Namespace:* {{ .Labels.namespace }}\n*Started:* {{ .StartsAt.Format \"2006-01-02 15:04:05 UTC\" }}\n{{ end }}\n{{ end }}\n\n{{ define \"email.syntax.subject\" }}[{{ .Status | toUpper }}] {{ .GroupLabels.alertname }} | {{ .GroupLabels.severity | toUpper }}{{ end }}\n\n{{ define \"email.syntax.body\" }}\nObservability Alert\n==========================\n\nStatus:   {{ .Status | toUpper }}\nAlert:    {{ .GroupLabels.alertname }}\nSeverity: {{ .GroupLabels.severity | toUpper }}\n\nAlerts:\n{{ range .Alerts }}\n- Summary:     {{ .Annotations.summary }}\n  Description: {{ .Annotations.description }}\n  Namespace:   {{ .Labels.namespace }}\n  Pod:         {{ .Labels.pod }}\n  Started:     {{ .StartsAt.Format \"2006-01-02 15:04:05 UTC\" }}\n{{ end }}\n\nThis alert was generated by Observability Stack.\n{{ end }}"
  },
  "template_file_provenances": {},
  "alertmanager_config": {
    "global": {
      "resolve_timeout": "5m"
    },
    "route": {
      "receiver": "p3-low",
      "group_by": [
        "grafana_folder",
        "alertname",
        "severity"
      ],
      "group_wait": "30s",
      "group_interval": "5m",
      "repeat_interval": "4h",
      "routes": [
        {
          "receiver": "p1-critical",
          "group_by": [
            "alertname",
            "severity",
            "namespace"
          ],
          "object_matchers": [
            [
              "severity",
              "=",
              "critical"
            ]
          ],
          "group_wait": "0s",
          "group_interval": "1m",
          "repeat_interval": "15m",
          "continue": false
        },
        {
          "receiver": "p2-high",
          "group_by": [
            "alertname",
            "severity",
            "namespace"
          ],
          "object_matchers": [
            [
              "severity",
              "=",
              "high"
            ]
          ],
          "group_wait": "1m",
          "group_interval": "5m",
          "repeat_interval": "1h",
          "continue": false
        },
        {
          "receiver": "p3-low",
          "group_by": [
            "alertname",
            "severity"
          ],
          "object_matchers": [
            [
              "severity",
              "=",
              "low"
            ]
          ],
          "group_wait": "5m",
          "group_interval": "10m",
          "repeat_interval": "8h",
          "continue": false
        }
      ]
    },
    "receivers": [
      {
        "name": "p1-critical",
        "grafana_managed_receiver_configs": [
          {
            "name": "PagerDuty - Critical",
            "type": "pagerduty",
            "disableResolveMessage": false,
            "settings": {
              "severity": "critical",
              "class": "kubernetes",
              "component": "{{ .GroupLabels.alertname }}",
              "group": "{{ .GroupLabels.namespace }}",
              "summary": "{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}",
              "description": "{{ range .Alerts }}{{ .Annotations.description }}{{ end }}"
            },
            "secureFields": {},
            "secureSettings": {
              "integrationKey": "25325e785254470bd0c47b09d45a4278"
            }
          }
        ]
      },
      {
        "name": "p2-high",
        "grafana_managed_receiver_configs": [
          {
            "name": "PagerDuty - High",
            "type": "pagerduty",
            "disableResolveMessage": false,
            "settings": {
              "severity": "warning",
              "class": "kubernetes",
              "component": "{{ .GroupLabels.alertname }}",
              "group": "{{ .GroupLabels.namespace }}",
              "summary": "{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}",
              "description": "{{ range .Alerts }}{{ .Annotations.description }}{{ end }}"
            },
            "secureFields": {},
            "secureSettings": {
              "integrationKey": "25325e785254470bd0c47b09d45a4278"
            }
          }
        ]
      },
      {
        "name": "p3-low",
        "grafana_managed_receiver_configs": [
          {
            "name": "PagerDuty - Low",
            "type": "pagerduty",
            "disableResolveMessage": false,
            "settings": {
              "severity": "info",
              "class": "kubernetes",
              "component": "{{ .GroupLabels.alertname }}",
              "group": "{{ .GroupLabels.namespace }}",
              "summary": "{{ range .Alerts }}{{ .Annotations.summary }}{{ end }}",
              "description": "{{ range .Alerts }}{{ .Annotations.description }}{{ end }}"
            },
            "secureFields": {},
            "secureSettings": {
              "integrationKey": "25325e785254470bd0c47b09d45a4278"
            }
          }
        ]
      }
    ]
  }
}